# ============================================================
# pinterest-agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Flask ---
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true

# --- Database ---
# Development (SQLite)
DATABASE_URL=sqlite:///instance/pinterest_agent.db
# Production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Admin credentials (first user — change after first login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# --- Pinterest API v5 ---
PINTEREST_APP_ID=1565782
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
# Board URL: https://www.pinterest.com/tissugeorgia/laptop-bags/

# --- kie.ai (Nano Banana Pro) ---
KIEAI_API_KEY=
KIEAI_MODEL=nano-banana-pro
# API docs: https://kie.ai/docs

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Discord Bot ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
# Interaction endpoint (for button callbacks):
# https://yourdomain.com/api/discord/interactions

# --- Meta Graph API ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_ACCOUNT_ID=
META_API_VERSION=v21.0

# --- Scheduler Timezone ---
SCHEDULER_TIMEZONE=Asia/Tbilisi
MORNING_JOB_HOUR=9
MORNING_JOB_MINUTE=0
EVENING_JOB_HOUR=20
EVENING_JOB_MINUTE=0

# --- Limits ---
MAX_REGENERATIONS=3
RECENT_PIN_CACHE_DAYS=7
MAX_UPLOAD_SIZE_MB=10

# --- Railway (production) ---
PORT=8000
