# ============================================================
# pinterest-agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Flask ---
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true

# --- Database ---
# Development (SQLite)
DATABASE_URL=sqlite:///instance/pinterest_agent.db
# Production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Admin credentials (first user — change after first login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# --- Pinterest API v5 ---
PINTEREST_APP_ID=1565782
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
# Bag board URL: https://www.pinterest.com/tissugeorgia/laptop-bags/
PINTEREST_BOARD_URL=https://www.pinterest.com/tissugeorgia/laptop-bags/
# Necklaces pull scene/lighting references from a separate (jewelry) board:
PINTEREST_BOARD_URL_JEWELRY=https://www.pinterest.com/tissugeorgia/jewelry/

# --- kie.ai (Nano Banana Pro) ---
KIE_AI_API_KEY=
KIE_AI_MODEL=nano-banana-pro
KIE_AI_TIMEOUT=60               # per-HTTP-call timeout (seconds)
KIE_AI_MAX_RETRIES=3            # retries on transient HTTP errors
KIE_AI_POLL_TIMEOUT_SEC=300     # max wait for the generation task to finish
# API docs: https://kie.ai/docs

# --- Seedance video (image-to-video) — uses the SAME KIE_AI_API_KEY above ---
# ALL OPTIONAL: sensible defaults are built in. Set only to override.
KIE_VIDEO_MODEL=bytedance/seedance-1.5-pro
KIE_VIDEO_ASPECT_RATIO=9:16     # 9:16 Reels/Shorts/Stories · 1:1 for feed
KIE_VIDEO_RESOLUTION=720p
KIE_VIDEO_DURATION=5            # seconds
KIE_VIDEO_GENERATE_AUDIO=false
KIE_VIDEO_POLL_TIMEOUT_SEC=600  # videos take longer than images

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Telegram Bot ---
# Telegram Bot (BotFather → @YourBotName)
TELEGRAM_BOT_TOKEN=  # 1234567890:AAEhBP0xxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal chat ID (from @userinfobot)
TELEGRAM_CHAT_ID=    # e.g. 123456789

# Optional: webhook URL (Stage 14 deployment — polling used in dev)
TELEGRAM_WEBHOOK_URL=

# --- Meta Graph API (Facebook Page + Instagram Business) ---
# Long-lived page access token (does NOT expire) — derived from extended user token.
# Verify with: python scripts/check_meta_token.py
FB_PAGE_TOKEN=

# Numeric page ID — Facebook → Page → About → Page ID
FB_PAGE_ID=

# IG Business Account ID — connected via Facebook Business Manager
# Get with: GET /{FB_PAGE_ID}?fields=instagram_business_account
IG_BUSINESS_ACCOUNT_ID=

# Graph API version — bump when Meta deprecates current
META_API_VERSION=v21.0

# --- Anthropic (Claude) — for AI caption generation ---
ANTHROPIC_API_KEY=
# Model — default Haiku 4.5 (cheapest, fast enough for captions)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Storefront API (Tissu bot — inventory + inspirations source) ---
STOREFRONT_API_BASE_URL=https://tissu-agent-production.up.railway.app
# Bags inventory: GET /api/storefront/products
STOREFRONT_API_KEY=
# Necklace reference photos: GET /api/inspirations?category=necklace (same host)
INSPIRATIONS_API_KEY=

# --- Iframe embedding (tissu-agent admin embeds our admin) ---
# Comma-separated list of origins that may load this app in an <iframe>.
IFRAME_PARENT_ORIGINS=https://tissu-agent-production.up.railway.app

# --- Scheduler Timezone ---
SCHEDULER_TIMEZONE=Asia/Tbilisi
# Morning: generates one bag AND one necklace → Telegram
MORNING_JOB_HOUR=9
MORNING_JOB_MINUTE=0
# Evening: bags post at 20:00, necklaces post at 22:00
EVENING_JOB_HOUR=20
EVENING_JOB_MINUTE=0
NECKLACE_POST_HOUR=22
NECKLACE_POST_MINUTE=0

# --- Limits ---
MAX_REGENERATIONS=3
RECENT_PIN_CACHE_DAYS=7
MAX_UPLOAD_SIZE_MB=10

# --- Railway (production) ---
PORT=8000
