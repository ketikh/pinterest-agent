# ============================================================
# pinterest-agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Flask ---
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true

# --- Database ---
# Development (SQLite)
DATABASE_URL=sqlite:///instance/pinterest_agent.db
# Production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Admin credentials (first user — change after first login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# --- Pinterest API v5 ---
PINTEREST_APP_ID=1565782
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
# Board URL: https://www.pinterest.com/tissugeorgia/laptop-bags/

# --- kie.ai (Nano Banana Pro) ---
KIEAI_API_KEY=
KIEAI_MODEL=nano-banana-pro
# API docs: https://kie.ai/docs

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Telegram Bot ---
# Telegram Bot (BotFather → @YourBotName)
TELEGRAM_BOT_TOKEN=  # 1234567890:AAEhBP0xxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal chat ID (from @userinfobot)
TELEGRAM_CHAT_ID=    # e.g. 123456789

# Optional: webhook URL (Stage 14 deployment — polling used in dev)
TELEGRAM_WEBHOOK_URL=

# --- Meta Graph API (Facebook Page + Instagram Business) ---
# Long-lived page access token (does NOT expire) — derived from extended user token.
# Verify with: python scripts/check_meta_token.py
FB_PAGE_TOKEN=

# Numeric page ID — Facebook → Page → About → Page ID
FB_PAGE_ID=

# IG Business Account ID — connected via Facebook Business Manager
# Get with: GET /{FB_PAGE_ID}?fields=instagram_business_account
IG_BUSINESS_ACCOUNT_ID=

# Graph API version — bump when Meta deprecates current
META_API_VERSION=v21.0

# --- Scheduler Timezone ---
SCHEDULER_TIMEZONE=Asia/Tbilisi
MORNING_JOB_HOUR=9
MORNING_JOB_MINUTE=0
EVENING_JOB_HOUR=20
EVENING_JOB_MINUTE=0

# --- Limits ---
MAX_REGENERATIONS=3
RECENT_PIN_CACHE_DAYS=7
MAX_UPLOAD_SIZE_MB=10

# --- Railway (production) ---
PORT=8000
