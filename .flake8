[flake8]
# Pragmatic settings — readability > strict style.
# Ignored:
#   E203 — whitespace before ':' (disagrees with black/PEP 8)
#   W503 — line break before binary operator (opposite of W504)
#   E501 — line too long (relax for tests + long URLs)
#   E702 — multiple statements on one line (tight test setup)
max-line-length = 100
extend-ignore = E203,W503,E501,E702

exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    migrations,
    build,
    dist

per-file-ignores =
    tests/*:F401,F811
