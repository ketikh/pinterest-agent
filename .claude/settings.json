{
  "permissions": {
    "allow": [
      "git status",
      "git diff",
      "git log",
      "git add",
      "git commit",
      "git checkout -b",
      "git branch",
      "git stash",
      "git stash pop",
      "ls",
      "find",
      "cat",
      "head",
      "tail",
      "wc",
      "python -m pytest",
      "pytest",
      "flake8",
      "black",
      "isort",
      "pip install",
      "pip list",
      "pip freeze",
      "flask db init",
      "flask db migrate",
      "flask db upgrade",
      "flask run"
    ],
    "deny": [
      "rm -rf /",
      "rm -rf ~",
      "rm -rf .",
      "rm -rf *",
      "git push --force",
      "git push -f",
      "git reset --hard",
      "git clean -f",
      "git clean -fd",
      "git checkout -- .",
      "git branch -D main",
      "git branch -D develop",
      "sudo",
      "su -",
      "chmod 777",
      "DROP TABLE",
      "DROP DATABASE",
      "TRUNCATE",
      "curl | bash",
      "wget | bash",
      "eval ",
      "exec "
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
